PORT=3010
NODE_ENV=development

# Preferred: dynamic destination from ATXP accounts
ATXP_CONNECTION_STRING=https://accounts.atxp.ai/?connection_token=YOUR_TOKEN

# Optional override for auth server
ATXP_SERVER=https://auth.atxp.ai

# Payer side for local probes / runtime.
# `atxp` is the preferred mode for Meridian's direct verify/settle runtime path.
# `base` and `polygon` are official onchain payer modes but not direct-settle-ready here.
# `cdp-base` is Meridian-owned experimental glue around Coinbase Server Wallets.
ATXP_PAYER_MODE=atxp
ATXP_PAYER_CONNECTION_STRING=https://accounts.atxp.ai/?connection_token=YOUR_TOKEN
ATXP_BASE_RPC_URL=
ATXP_BASE_PRIVATE_KEY=
ATXP_POLYGON_RPC_URL=
ATXP_POLYGON_PRIVATE_KEY=
ATXP_POLYGON_CHAIN_ID=80002
CDP_SERVICE_URL=http://localhost:3030
ATXP_CDP_ACCOUNT_NAME=meridian-atxp-payer
ATXP_CDP_ACCOUNT_UNIQUE=false
ATXP_CDP_TREASURY_ADDRESS=
ATXP_CDP_TREASURY_NATIVE_TOPUP=0.00002
ATXP_CDP_TREASURY_USDC_TOPUP_UNITS=1000000
ATXP_MCP_SERVER=http://localhost:3010/mcp
ATXP_TEST_MERCHANT=demo-merchant
ATXP_TEST_AMOUNT_USD=0.25
ATXP_PROBE_MODE=
